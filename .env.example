# ============================================================
# BET MORE - Environment Variables
# ============================================================
# Copy this to .env.local and fill in your values

# ------ API Keys ------

# Anthropic API key for Haiku AI reasoning
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: RugCheck API key (free tier works without one)
RUGCHECK_API_KEY=

# ------ Solana Config ------

# Solana RPC endpoint (Helius recommended for production)
# Free tier: https://dev.helius.xyz/
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com

# ------ Token Gating (Scanner) ------

# Your NEW token's mint address (after migration)
NEXT_PUBLIC_GATE_TOKEN_MINT=NEW_TOKEN_MINT_ADDRESS

# Token gating thresholds (raw amount with decimals)
# BET has 6 decimals: 1000 tokens = 1000000000
NEXT_PUBLIC_GATE_TIER_HOLDER=1000000000
NEXT_PUBLIC_GATE_TIER_WHALE=10000000000

# ------ Migration / Claim ------

# Old token mint (the current BET on Raydium)
NEXT_PUBLIC_OLD_TOKEN_MINT=OLD_BET_MINT_ADDRESS

# New token mint (created on pump.fun)
NEXT_PUBLIC_NEW_TOKEN_MINT=NEW_BET_MINT_ADDRESS

# Treasury wallet private key (JSON array or base58)
# This wallet holds the claim pool tokens.
# SECURITY: Use a DEDICATED wallet. Only fund it with BET + minimal SOL for fees.
# Never put your main wallet key here.
#
# To export from Phantom: Settings > Security > Export Private Key
# Then convert to JSON array format:
#   node -e "console.log(JSON.stringify(Array.from(require('bs58').decode('YOUR_KEY'))))"
#
TREASURY_PRIVATE_KEY=[]
