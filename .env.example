# ============================================================
# BET MORE - Environment Variables
# ============================================================
# Copy this to .env.local and fill in your values

# ------ API Keys ------

# Anthropic API key for Haiku AI reasoning
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: RugCheck API key (free tier works without one)
RUGCHECK_API_KEY=

# ------ Solana Config ------

# Solana RPC endpoint (server-side only, never exposed to browser)
# Helius recommended — free tier: https://dev.helius.xyz/
SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ------ Token Gating (Scanner) ------

# BET token mint address
NEXT_PUBLIC_GATE_TOKEN_MINT=5CLSw4viyMLfnRHHxZpDF8CuZt5e1ceq1AJqd4GjAJNX

# Token gating thresholds (raw amount with decimals)
# BET has 6 decimals: 1000 tokens = 1000000000
NEXT_PUBLIC_GATE_TIER_HOLDER=1000000000
NEXT_PUBLIC_GATE_TIER_WHALE=10000000000
